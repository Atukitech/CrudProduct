<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:background="@color/white"
    android:paddingHorizontal="20dp"
    android:layout_height="match_parent"
    tools:context=".AddActivity">

    <TextView
        android:id="@+id/title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:padding="8dp"
        android:text="Add Product"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/nameET"
        android:hint="Product Name:"
        android:padding="8dp"
        android:layout_marginTop="80dp"
        android:textSize="18sp"
        android:textColor="@color/black"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title"/>
    <EditText
        android:id="@+id/quantityET"
        android:hint="Quantity:"
        android:padding="8dp"
        android:layout_marginTop="30dp"
        android:textSize="18sp"
        android:textColor="@color/black"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="@id/nameET"
        app:layout_constraintEnd_toEndOf="@id/nameET"
        app:layout_constraintTop_toBottomOf="@id/nameET"/>
    <EditText
        android:id="@+id/priceET"
        android:hint="Price:"
        android:padding="8dp"
        android:layout_marginTop="30dp"
        android:textSize="18sp"
        android:textColor="@color/black"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="@id/quantityET"
        app:layout_constraintEnd_toEndOf="@id/quantityET"
        app:layout_constraintTop_toBottomOf="@id/quantityET"/>
    <EditText
        android:id="@+id/categoryET"
        android:hint="Category:"
        android:padding="8dp"
        android:layout_marginTop="30dp"
        android:textSize="18sp"
        android:textColor="@color/black"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="@id/priceET"
        app:layout_constraintEnd_toEndOf="@id/priceET"
        app:layout_constraintTop_toBottomOf="@id/priceET"/>
    <EditText
        android:id="@+id/availableET"
        android:hint="Available:"
        android:padding="8dp"
        android:layout_marginTop="30dp"
        android:textSize="18sp"
        android:textColor="@color/black"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="@id/categoryET"
        app:layout_constraintEnd_toEndOf="@id/categoryET"
        app:layout_constraintTop_toBottomOf="@id/categoryET"/>

    <Button
        android:id="@+id/button"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:text="Save"
        android:textColor="@color/white"
        android:textSize="30sp"
        android:layout_marginTop="50dp"
        android:backgroundTint="@color/back"
        app:layout_constraintEnd_toEndOf="@+id/availableET"
        app:layout_constraintStart_toStartOf="@+id/availableET"
        app:layout_constraintTop_toBottomOf="@+id/availableET" />

</androidx.constraintlayout.widget.ConstraintLayout>